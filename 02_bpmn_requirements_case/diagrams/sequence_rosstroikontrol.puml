@startuml
actor "Прораб" as P
participant "Битрикс24" as B24
participant "Генподрядчик" as GC
participant "Единая система Росстройконтроля" as RSK

P -> B24: Загрузить акт КС-2, подписанный генподрядчиком
B24 -> B24: Проверить, что документ финальный
B24 -> RSK: POST /api/v1/acceptance_report
activate RSK
note right of RSK: Передаются: номер акта,\nдата, объёмы, скан, подписи
RSK -> RSK: Валидация, регистрация
RSK --> B24: 202 Accepted (регистрационный номер)
deactivate RSK
B24 -> P: Уведомление "Акт передан в Росстройконтроль"
RSK -> RSK: Плановая проверка (до 10 дней)
alt Нарушения
    RSK -> B24: POST /webhook/violation (предписание)
    B24 -> P: Создать задачу "Устранить нарушение"
    P -> B24: Загрузить акт об устранении
    B24 -> RSK: Повторная отправка
else Нет нарушений
    RSK -> B24: POST /webhook/approved
    B24 -> P: "Акт принят Росстройконтролем"
end
@enduml
